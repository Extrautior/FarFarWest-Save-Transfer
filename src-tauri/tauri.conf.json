{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Far Far West Save Studio",
  "version": "2.1.4",
  "identifier": "com.extrautior.farfarwestsavestudio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Far Far West Save Studio",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
