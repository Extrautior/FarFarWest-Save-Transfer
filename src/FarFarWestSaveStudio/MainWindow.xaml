<Window x:Class="FarFarWestSaveStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Far Far West Save Studio" Height="760" Width="1180" MinHeight="680" MinWidth="1040"
        Background="#0B0F1A" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#0B0F1A"/>
        <SolidColorBrush x:Key="Panel" Color="#121826"/>
        <SolidColorBrush x:Key="Panel2" Color="#172033"/>
        <SolidColorBrush x:Key="Text" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="Muted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Accent" Color="#6D5EF6"/>
        <SolidColorBrush x:Key="Border" Color="#263247"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#070A13">
            <DockPanel Margin="20,28">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Far Far West" Foreground="{StaticResource Text}" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="Save Studio" Foreground="{StaticResource Muted}" FontSize="14" Margin="0,2,0,28"/>
                    <Button x:Name="TransferNav" Content="Transfer" HorizontalContentAlignment="Left" Margin="0,0,0,8" Click="ShowTransfer"/>
                    <Button x:Name="EditorNav" Content="Editor" HorizontalContentAlignment="Left" Background="Transparent" Margin="0,0,0,8" Click="ShowEditor"/>
                    <Button x:Name="ActivityNav" Content="Activity" HorizontalContentAlignment="Left" Background="Transparent" Click="ShowActivity"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Bottom" Text="Unofficial save tool&#x0a;Always keep backups." Foreground="{StaticResource Muted}" FontSize="12"/>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30,26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Margin="0,0,0,18">
                <TextBlock x:Name="PageTitle" Text="Transfer" Foreground="{StaticResource Text}" FontSize="32" FontWeight="Bold"/>
                <TextBlock x:Name="StatusText" DockPanel.Dock="Right" Text="Ready" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
            </DockPanel>

            <Grid x:Name="TransferPage" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.45*"/>
                    <ColumnDefinition Width="0.95*"/>
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource Panel}" CornerRadius="20" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="22" Margin="0,0,18,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.ColumnSpan="2" Text="Move a save to another Steam account" Foreground="{StaticResource Text}" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="Pick a source save and choose the target account from the list on the right." Foreground="{StaticResource Muted}" Margin="0,4,0,18"/>

                        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="Old save file" Foreground="{StaticResource Muted}" FontWeight="SemiBold" Margin="0,4"/>
                        <TextBox x:Name="SourceSaveBox" Grid.Row="3" Margin="0,0,10,12"/>
                        <Button Grid.Row="3" Grid.Column="1" Content="Browse" Click="BrowseSource"/>

                        <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="Source SteamID64" Foreground="{StaticResource Muted}" FontWeight="SemiBold" Margin="0,4"/>
                        <TextBox x:Name="SourceSteamIdBox" Grid.Row="5" Margin="0,0,10,12"/>
                        <Button Grid.Row="5" Grid.Column="1" Content="Detect" Click="DetectSource"/>

                        <TextBlock Grid.Row="6" Grid.ColumnSpan="2" Text="Target SteamID64" Foreground="{StaticResource Muted}" FontWeight="SemiBold" Margin="0,4"/>
                        <TextBox x:Name="TargetSteamIdBox" Grid.Row="7" Grid.ColumnSpan="2" Margin="0,0,0,12"/>

                        <TextBlock Grid.Row="8" Grid.ColumnSpan="2" Text="Output save file" Foreground="{StaticResource Muted}" FontWeight="SemiBold" Margin="0,4"/>
                        <TextBox x:Name="OutputBox" Grid.Row="9" Margin="0,0,10,12"/>
                        <Button Grid.Row="9" Grid.Column="1" Content="Save As" Click="BrowseOutput"/>

                        <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Margin="0,6,0,0">
                            <CheckBox x:Name="RewriteCheck" Content="Replace old SteamID text inside decrypted payload" Foreground="{StaticResource Text}" IsChecked="True" Margin="0,4"/>
                            <TextBlock Text="Party suffix" Foreground="{StaticResource Muted}" FontWeight="SemiBold" Margin="0,12,0,4"/>
                            <TextBox x:Name="PartySuffixBox" Text="NicoArnoEvilRaptorFireshineRobbo"/>
                        </StackPanel>

                        <Button Grid.Row="11" Grid.ColumnSpan="2" Content="Transfer Save" Background="#22C55E" Margin="0,20,0,0" Click="TransferSave"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource Panel}" CornerRadius="20" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Target account" Foreground="{StaticResource Text}" FontSize="22" FontWeight="Bold"/>
                        <DockPanel Grid.Row="1" Margin="0,14,0,14">
                            <TextBox x:Name="ProfileBox" MinWidth="220" DockPanel.Dock="Left" ToolTip="Steam URL, vanity, or SteamID64"/>
                            <Button Content="Resolve" Margin="10,0,0,0" Click="ResolveProfile"/>
                        </DockPanel>
                        <TextBlock Grid.Row="2" Text="Local accounts" Foreground="{StaticResource Muted}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ListBox x:Name="AccountsList" Grid.Row="3" Background="#0B1220" BorderBrush="{StaticResource Border}" Foreground="{StaticResource Text}" ScrollViewer.VerticalScrollBarVisibility="Auto" SelectionChanged="AccountSelected" VirtualizingPanel.IsVirtualizing="True">
                            <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" CornerRadius="19" Background="{StaticResource Accent}" ClipToBounds="True">
                                    <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
                                            <TextBlock Text="{Binding SteamId}" Foreground="{StaticResource Muted}" FontSize="12"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="EditorPage" Grid.Row="1" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="{StaticResource Panel}" CornerRadius="20" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="14" Margin="0,0,18,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Categories" Foreground="{StaticResource Text}" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ListBox x:Name="CategoryList" Background="Transparent" BorderThickness="0" Foreground="{StaticResource Text}" SelectionChanged="CategorySelected"/>
                    </DockPanel>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource Panel}" CornerRadius="20" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="18" Margin="0,0,0,14">
                        <DockPanel>
                            <StackPanel>
                                <TextBlock Text="Runtime inventory editor" Foreground="{StaticResource Text}" FontSize="22" FontWeight="Bold"/>
                                <TextBlock x:Name="EditorSummary" Text="Load a save to edit values." Foreground="{StaticResource Muted}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Content="Load Current Save" Click="LoadEditorSave"/>
                        </DockPanel>
                    </Border>
                    <TextBox x:Name="SearchBox" Grid.Row="1" Margin="0,0,0,12" TextChanged="FilterChanged"/>
                    <DataGrid x:Name="InventoryGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" Background="#0B1220" Foreground="{StaticResource Text}" BorderBrush="{StaticResource Border}" RowBackground="#111827" AlternatingRowBackground="#0F172A" GridLinesVisibility="None" EnableRowVirtualization="True" EnableColumnVirtualization="True" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Grid.Row="3" Content="Save Edited Copy" HorizontalAlignment="Right" Background="#22C55E" Margin="0,14,0,0" Click="SaveEdited"/>
                </Grid>
            </Grid>

            <Grid x:Name="ActivityPage" Grid.Row="1" Visibility="Collapsed">
                <TextBox x:Name="LogBox" Background="#0B1220" Foreground="{StaticResource Text}" BorderBrush="{StaticResource Border}" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
